Replace the upstream qualified app name with @bundleId@, filled in at
build time by the overlay. This keeps the LaunchAgent plist Label and
AssociatedBundleIdentifiers consistent with CFBundleIdentifier when the
app is re-signed under a different identity.

--- a/src/main.cpp
+++ b/src/main.cpp
@@ -72,5 +72,5 @@
     Application::setApplicationName("KeePassXC");
     Application::setApplicationVersion(KEEPASSXC_VERSION);
-    app.setProperty("KPXC_QUALIFIED_APPNAME", "org.keepassxc.KeePassXC");
+    app.setProperty("KPXC_QUALIFIED_APPNAME", "@bundleId@");

     // HACK: Prevent long-running threads from deadlocking the program with only 1 CPU
